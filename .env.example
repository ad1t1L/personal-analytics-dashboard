# Local dev: use SQLite (default). No DATABASE_URL needed.
# To force SQLite when DATABASE_URL is set (e.g. for MySQL prod), add:
# USE_SQLITE=1

# Production MySQL (optional):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/plannerhub

SECRET_KEY=CHANGE_ME_BEFORE_DEPLOY

# Email (optional). If SMTP_USER + SMTP_PASSWORD are unset, SMTP is skipped and
# new accounts are created already verified (good for local dev).
# Gmail: use a Google "App password" (2FA on), not your normal password.
# FROM_EMAIL defaults to SMTP_USER if omitted.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# FROM_EMAIL=your@gmail.com
# APP_BASE_URL=http://localhost:8000

# Force-disable SMTP even when credentials exist (optional)
# DISABLE_SMTP_SENDING=1

# Force-enable SMTP only if SMTP_USER and SMTP_PASSWORD are set (optional)
# DISABLE_SMTP_SENDING=0
