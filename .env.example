# Local dev: use SQLite (default). No DATABASE_URL needed.
# To force SQLite when DATABASE_URL is set (e.g. for MySQL prod), add:
# USE_SQLITE=1

# Production MySQL (optional):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/plannerhub

SECRET_KEY=CHANGE_ME_BEFORE_DEPLOY

# Email (required for verification, password reset, email 2FA)
# Use an app password for Gmail; FROM_EMAIL should match your sender identity.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=your@gmail.com
# APP_BASE_URL=http://localhost:8000
